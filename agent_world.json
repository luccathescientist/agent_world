{
  "openclaw": {
    "home": "~/.openclaw",
    "mediaDir": "",
    "allowedFileRoots": []
  },
  "voice": {
    "provider": "openai",
    "apiKeyEnv": "OPENAI_API_KEY",
    "transcribeModel": "gpt-4o-mini-transcribe",
    "speechModel": "gpt-4o-mini-tts",
    "defaultVoice": "nova",
    "speechFormat": "mp3"
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8890
  }
}
